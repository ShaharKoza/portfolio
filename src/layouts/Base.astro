---
import '../styles/global.css';
import ContactLinks from '../components/ContactLinks.astro';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);

const nav = [
  { href: '/projects/', label: 'Projects' },
  { href: '/writing/', label: 'Writing' },
  { href: '/about/', label: 'About' },
];
const path = Astro.url.pathname;
const year = new Date().getFullYear();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL('/og.png', Astro.site)} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={new URL('/og.png', Astro.site)} />
    <meta name="theme-color" content="#f4efe4" />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>


    <header class="site-header">
      <div class="container header-inner">
        <a class="wordmark" href="/">Shahar Kozniak<span class="gradient-text">.</span></a>
        <nav aria-label="Main">
          <ul>
            {
              nav.map((item) => (
                <li>
                  <a
                    href={item.href}
                    aria-current={path.startsWith(item.href) ? 'page' : undefined}
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
            <li class="nav-sep" aria-hidden="true"></li>
            <li>
              <a class="nav-icon" href="https://github.com/ShaharKoza" target="_blank" rel="noopener" aria-label="GitHub" title="GitHub">
                <svg width="18" height="18" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
              </a>
            </li>
            <li>
              <a class="nav-icon" href="https://www.linkedin.com/in/shahar-kozniak" target="_blank" rel="noopener" aria-label="LinkedIn" title="LinkedIn">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.47-.9 1.63-1.85 3.36-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.55V9h3.57v11.45zM22.23 0H1.77C.79 0 0 .77 0 1.72v20.55C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.23 0z"/></svg>
              </a>
            </li>
          </ul>
        </nav>
      </div>
    </header>

    <main id="main" class="container">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <ContactLinks />
        <p class="muted">Designed &amp; built by Shahar Kozniak · © {year}</p>
      </div>
    </footer>

    <script is:inline data-external-links-blank>
    // כל קישור חיצוני נפתח בטאב חדש - לא מאבדים את המבקר
    document.querySelectorAll('a[href^="http"]').forEach((a) => {
      if (new URL(a.href).host !== location.host) {
        a.target = '_blank';
        a.rel = 'noopener';
      }
    });
  </script>
</body>
</html>

<style>
  .skip-link {
    position: absolute;
    inset-inline-start: var(--space-lg);
    top: -100%;
    background: var(--accent);
    color: #fff;
    padding: var(--space-xs) var(--space-md);
    border-radius: 0 0 var(--radius-sm) var(--radius-sm);
    z-index: 30;
  }

  .skip-link:focus {
    top: 0;
    color: #fff;
  }

  /* --- Header --- */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    background: rgba(244, 239, 228, 0.85);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--line);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-lg);
    padding-block: var(--space-md);
  }

  .wordmark {
    font-family: var(--font-display);
    font-weight: 640;
    font-size: var(--text-md);
    letter-spacing: -0.01em;
  }

  .wordmark:hover {
    color: var(--ink);
  }

  nav ul {
    display: flex;
    gap: var(--space-lg);
    list-style: none;
    padding: 0;
  }

  nav a {
    color: var(--ink-soft);
    font-size: var(--text-sm);
    font-weight: 500;
  }

  nav a:hover {
    color: var(--ink);
  }

  nav a[aria-current='page'] {
    color: var(--ink);
    text-decoration: underline;
    text-underline-offset: 7px;
    text-decoration-thickness: 2px;
    text-decoration-color: var(--accent);
  }

  main {
    flex: 1;
    width: min(var(--width-content), 100% - 2 * var(--space-lg));
  }

  /* --- Footer --- */
  .site-footer {
    border-top: 1px solid var(--line);
    margin-top: var(--space-3xl);
    background: transparent;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-lg);
    padding-block: var(--space-xl);
    flex-wrap: wrap;
  }

  .footer-inner p {
    font-size: var(--text-sm);
  }

  .nav-sep {
    width: 1px;
    height: 1.1rem;
    background: var(--line);
    align-self: center;
  }

  .nav-icon {
    display: inline-flex;
    align-items: center;
    color: var(--ink-soft);
    transition: color 0.15s ease;
  }

  .nav-icon:hover {
    color: var(--accent);
  }
</style>
