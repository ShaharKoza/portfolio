---
import '../styles/global.css';
import ContactLinks from '../components/ContactLinks.astro';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);

const nav = [
  { href: '/projects/', label: 'Projects' },
  { href: '/writing/', label: 'Writing' },
  { href: '/about/', label: 'About' },
];
const path = Astro.url.pathname;
const year = new Date().getFullYear();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="theme-color" content="#08070d" />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>

    <div class="aurora" aria-hidden="true">
      <div class="blob blob-violet"></div>
      <div class="blob blob-cyan"></div>
      <div class="blob blob-pink"></div>
      <div class="grid-overlay"></div>
    </div>
    <div class="spotlight" aria-hidden="true"></div>

    <header class="site-header">
      <div class="container header-inner">
        <a class="wordmark" href="/">Shahar Kozniak<span class="gradient-text">.</span></a>
        <nav aria-label="Main">
          <ul>
            {
              nav.map((item) => (
                <li>
                  <a
                    href={item.href}
                    aria-current={path.startsWith(item.href) ? 'page' : undefined}
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
      </div>
    </header>

    <main id="main" class="container">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <ContactLinks />
        <p class="muted">Designed &amp; built by Shahar Kozniak · © {year}</p>
      </div>
    </footer>

    <script>
      // Scroll reveal
      const revealed = document.querySelectorAll('[data-reveal]');
      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.12 }
      );
      revealed.forEach((el) => observer.observe(el));

      const finePointer = matchMedia('(pointer: fine)').matches;
      const noMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;

      // Mouse-follow highlight inside glow cards
      if (finePointer) {
        document.addEventListener('pointermove', (e) => {
          const card = (e.target as Element | null)?.closest?.('.glow-card');
          if (card instanceof HTMLElement) {
            const rect = card.getBoundingClientRect();
            card.style.setProperty('--mx', `${e.clientX - rect.left}px`);
            card.style.setProperty('--my', `${e.clientY - rect.top}px`);
          }
        });
      }

      // Cursor spotlight that trails the pointer
      const spot = document.querySelector<HTMLElement>('.spotlight');
      if (spot && finePointer && !noMotion) {
        let tx = innerWidth / 2;
        let ty = innerHeight / 3;
        let x = tx;
        let y = ty;
        addEventListener('pointermove', (e) => {
          tx = e.clientX;
          ty = e.clientY;
        });
        const tick = () => {
          x += (tx - x) * 0.08;
          y += (ty - y) * 0.08;
          spot.style.transform = `translate(${x - 300}px, ${y - 300}px)`;
          requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      }
    </script>
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    inset-inline-start: var(--space-lg);
    top: -100%;
    background: var(--violet);
    color: #fff;
    padding: var(--space-xs) var(--space-md);
    border-radius: 0 0 var(--radius-sm) var(--radius-sm);
    z-index: 30;
  }

  .skip-link:focus {
    top: 0;
    color: #fff;
  }

  /* --- Animated aurora background --- */
  .aurora {
    position: fixed;
    inset: 0;
    z-index: -2;
    overflow: hidden;
    background: var(--bg);
  }

  .blob {
    position: absolute;
    width: 44vmax;
    height: 44vmax;
    border-radius: 50%;
    filter: blur(90px);
    opacity: 0.35;
    will-change: transform;
  }

  .blob-violet {
    background: var(--violet);
    top: -12vmax;
    left: -8vmax;
    animation: drift-a 26s ease-in-out infinite alternate;
  }

  .blob-cyan {
    background: var(--cyan);
    top: 30%;
    right: -16vmax;
    opacity: 0.22;
    animation: drift-b 32s ease-in-out infinite alternate;
  }

  .blob-pink {
    background: var(--pink);
    bottom: -18vmax;
    left: 22%;
    opacity: 0.18;
    animation: drift-c 38s ease-in-out infinite alternate;
  }

  @keyframes drift-a {
    to {
      transform: translate(14vmax, 10vmax) scale(1.15);
    }
  }

  @keyframes drift-b {
    to {
      transform: translate(-12vmax, -8vmax) scale(0.9);
    }
  }

  @keyframes drift-c {
    to {
      transform: translate(-10vmax, -12vmax) scale(1.2);
    }
  }

  .grid-overlay {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.035) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.035) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: radial-gradient(ellipse 90% 60% at 50% 0%, black 20%, transparent 75%);
  }

  .spotlight {
    position: fixed;
    top: 0;
    left: 0;
    width: 600px;
    height: 600px;
    z-index: -1;
    pointer-events: none;
    background: radial-gradient(circle, rgba(139, 92, 246, 0.09) 0%, transparent 60%);
  }

  /* --- Header --- */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    background: rgba(8, 7, 13, 0.65);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--line);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-lg);
    padding-block: var(--space-md);
  }

  .wordmark {
    font-family: var(--font-display);
    font-weight: 640;
    font-size: var(--text-md);
    letter-spacing: -0.01em;
  }

  .wordmark:hover {
    color: var(--ink);
  }

  nav ul {
    display: flex;
    gap: var(--space-lg);
    list-style: none;
    padding: 0;
  }

  nav a {
    color: var(--ink-soft);
    font-size: var(--text-sm);
    font-weight: 500;
  }

  nav a:hover {
    color: var(--ink);
  }

  nav a[aria-current='page'] {
    color: var(--ink);
    text-decoration: underline;
    text-underline-offset: 7px;
    text-decoration-thickness: 2px;
    text-decoration-color: var(--violet);
  }

  main {
    flex: 1;
    width: min(var(--width-content), 100% - 2 * var(--space-lg));
  }

  /* --- Footer --- */
  .site-footer {
    border-top: 1px solid var(--line);
    margin-top: var(--space-3xl);
    background: rgba(8, 7, 13, 0.5);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-lg);
    padding-block: var(--space-xl);
    flex-wrap: wrap;
  }

  .footer-inner p {
    font-size: var(--text-sm);
  }

  @media (prefers-reduced-motion: reduce) {
    .spotlight {
      display: none;
    }
  }
</style>
