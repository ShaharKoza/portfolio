---
const links = [
  { href: 'https://github.com/ShaharKoza', label: 'GitHub ↗', external: true },
  { href: 'https://www.linkedin.com/in/shahar-kozniak', label: 'LinkedIn ↗', external: true },
  { href: 'mailto:kshahar1315@gmail.com', label: '✉ kshahar1315@gmail.com', external: false },
  { href: '/Shahar-Kozniak-CV.pdf', label: 'Download CV (PDF)', external: true },
];
---

<ul class="contact-links">
  {
    links.map((link) => (
      <li>
        <a href={link.href} target={link.external ? "_blank" : undefined} rel={link.external ? "noopener" : undefined}>{link.label}</a>
      </li>
    ))
  }
</ul>

<style>
  .contact-links {
    display: flex;
    gap: var(--space-lg);
    list-style: none;
    padding: 0;
  }

  .contact-links a {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--ink-soft);
  }

  .contact-links a:hover {
    color: var(--cyan);
  }
</style>
