---
// Editorial index row (replaced the boxed card).
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, summary, year, tags } = project.data;
---

<article class="row">
  <a href={`/projects/${project.id}/`} class="row-link">
    <span class="year">{year}</span>
    <span class="body">
      <span class="title">{title}</span>
      <span class="summary muted">{summary}</span>
      {tags.length > 0 && <span class="tech muted">{tags.join(' · ')}</span>}
    </span>
    <span class="arrow" aria-hidden="true">→</span>
  </a>
</article>

<style>
  .row {
    border-top: 1px solid var(--line);
  }

  .row:last-child {
    border-bottom: 1px solid var(--line);
  }

  .row-link {
    display: grid;
    grid-template-columns: 5.5rem 1fr auto;
    align-items: baseline;
    column-gap: var(--space-lg);
    padding-block: var(--space-lg);
  }

  .year {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--ink-soft);
  }

  .body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
  }

  .title {
    font-weight: 600;
    font-size: var(--text-lg);
    line-height: 1.25;
    transition: color var(--transition);
  }

  .row-link:hover .title {
    color: var(--accent);
  }

  .summary {
    font-size: var(--text-base);
    max-width: 52ch;
  }

  .tech {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    margin-top: var(--space-2xs);
  }

  .arrow {
    color: var(--ink-soft);
    transition: transform var(--transition), color var(--transition);
  }

  .row-link:hover .arrow {
    color: var(--accent);
    transform: translateX(4px);
  }

  @media (max-width: 640px) {
    .row-link {
      grid-template-columns: 1fr auto;
    }

    .year {
      grid-column: 1 / -1;
      margin-bottom: var(--space-2xs);
    }
  }
</style>
