---
// Editorial three-column work row, per the design reference:
// [year | title | description + stack], hover shifts inward and warms to accent.
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, summary, year, tags } = project.data;
---

<a href={`/projects/${project.id}/`} class="row">
  <span class="year">{year}</span>
  <span class="title">{title}</span>
  <span class="detail">
    <span class="desc">{summary}</span>
    {tags.length > 0 && <span class="stack">{tags.join(' · ')}</span>}
  </span>
</a>

<style>
  .row {
    display: grid;
    grid-template-columns: 96px 1fr 360px;
    gap: 32px;
    align-items: baseline;
    padding-block: 24px;
    border-top: 1px solid var(--line-soft);
    transition: color var(--transition), padding-inline-start 250ms ease;
  }

  .row:last-of-type {
    border-bottom: 1px solid var(--line-soft);
  }

  .row:hover {
    color: var(--accent);
    padding-inline-start: 10px;
  }

  .year {
    font-family: var(--font-mono);
    font-size: var(--text-micro);
    color: var(--ink-55);
  }

  .title {
    font-size: var(--text-row);
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .detail {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .desc {
    font-size: 13px;
    line-height: 1.65;
    color: var(--ink-65);
  }

  .stack {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-55);
  }

  @media (max-width: 860px) {
    .row {
      grid-template-columns: 1fr;
      gap: 8px;
    }

    .row:hover {
      padding-inline-start: 0;
    }
  }
</style>
