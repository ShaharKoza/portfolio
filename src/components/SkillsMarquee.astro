---
// Static, grouped skills list. Replaced the animated marquee ticker:
// grouping communicates competence better than motion.
const groups = [
  {
    label: 'AI & Automation',
    items: ['AI Agents', 'LLM Orchestration', 'Claude & GPT APIs', 'Automation Pipelines'],
  },
  {
    label: 'Languages & Back-End',
    items: ['Python', 'TypeScript', 'Node.js', 'Express', 'PowerShell', 'REST APIs'],
  },
  {
    label: 'Data & Infra',
    items: ['PostgreSQL', 'Prisma', 'Firebase', 'Docker', 'Automated Testing'],
  },
  {
    label: 'Hardware & Web',
    items: ['Raspberry Pi', 'IoT & Sensors', 'Astro', 'Vanilla JS'],
  },
];
---

<dl class="skills">
  {
    groups.map((group) => (
      <div class="skills-row">
        <dt>{group.label}</dt>
        <dd>
          <ul aria-label={group.label}>
            {group.items.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </dd>
      </div>
    ))
  }
</dl>

<style>
  .skills {
    display: flex;
    flex-direction: column;
    margin: 0;
  }

  .skills-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xs) var(--space-xl);
    padding-block: var(--space-md);
    border-top: 1px solid var(--line);
  }

  .skills-row:last-child {
    border-bottom: 1px solid var(--line);
  }

  @media (min-width: 720px) {
    .skills-row {
      grid-template-columns: 14rem 1fr;
      align-items: baseline;
    }
  }

  dt {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }

  dd {
    margin: 0;
  }

  ul {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs) var(--space-md);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  li {
    font-size: var(--text-base);
    color: var(--ink);
  }

  li + li::before {
    content: '·';
    color: var(--ink-soft);
    margin-inline-end: var(--space-md);
  }
</style>
