---
const rowA = [
  'TypeScript',
  'Node.js',
  'Express',
  'PostgreSQL',
  'Prisma',
  'Python',
  'PowerShell',
  'Windows Infrastructure',
  'Docker',
  'Git',
];

const rowB = [
  'AI Agents',
  'LLM Orchestration',
  'Claude & GPT APIs',
  'Raspberry Pi',
  'IoT & Sensors',
  'Security & RBAC',
  'Automated Testing',
  'Vanilla JS',
  'Astro',
  'REST APIs',
];
---

<div class="marquee-wrap" data-reveal>
  {
    [rowA, rowB].map((row, i) => (
      <div class={`marquee ${i === 1 ? 'reverse' : ''}`}>
        <ul class="track" aria-hidden={i === 1 ? undefined : undefined}>
          {[...row, ...row].map((skill, j) => (
            <li aria-hidden={j >= row.length ? 'true' : undefined}>{skill}</li>
          ))}
        </ul>
      </div>
    ))
  }
</div>

<style>
  .marquee-wrap {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .marquee {
    overflow: hidden;
    mask-image: linear-gradient(90deg, transparent, black 12%, black 88%, transparent);
  }

  .track {
    display: flex;
    gap: var(--space-md);
    width: max-content;
    list-style: none;
    padding: 0;
    animation: scroll 36s linear infinite;
  }

  .reverse .track {
    animation-direction: reverse;
  }

  .marquee:hover .track {
    animation-play-state: paused;
  }

  .track li {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--ink-soft);
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.45rem 1.2rem;
    white-space: nowrap;
    transition: color var(--transition), border-color var(--transition), box-shadow var(--transition);
  }

  .track li:hover {
    color: var(--ink);
    border-color: rgba(34, 211, 238, 0.5);
    box-shadow: 0 0 18px var(--glow-cyan);
  }

  @keyframes scroll {
    to {
      transform: translateX(calc(-50% - var(--space-md) / 2));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .track {
      animation: none;
      flex-wrap: wrap;
      width: auto;
    }

    .marquee {
      mask-image: none;
    }
  }
</style>
