---
// "Practice" grid: four mono-labelled columns, per the design reference.
const groups = [
  {
    name: 'AI & Automation',
    items: ['AI Agents', 'LLM Orchestration', 'Claude & GPT APIs', 'Automation Pipelines'],
  },
  {
    name: 'Languages & Back-End',
    items: ['Python', 'TypeScript', 'Node.js', 'Express', 'PowerShell', 'REST APIs'],
  },
  {
    name: 'Data & Infra',
    items: ['PostgreSQL', 'Prisma', 'Docker', 'Windows Infrastructure', 'Security & RBAC'],
  },
  {
    name: 'Hardware & Web',
    items: ['Raspberry Pi', 'IoT & Sensors', 'Astro', 'Vanilla JS', 'Automated Testing'],
  },
];
---

<div class="practice">
  {
    groups.map((group) => (
      <div class="group">
        <h3>{group.name}</h3>
        <ul>
          {group.items.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    ))
  }
</div>

<style>
  .practice {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 36px;
  }

  h3 {
    margin: 0 0 14px;
    font-family: var(--font-mono);
    font-size: 10.5px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-55);
  }

  ul {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  li {
    font-size: var(--text-meta);
    color: var(--ink-85);
  }

  @media (max-width: 900px) {
    .practice {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 520px) {
    .practice {
      grid-template-columns: 1fr;
    }
  }
</style>
