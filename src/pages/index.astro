---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Section from '../components/Section.astro';
import ProjectCard from '../components/ProjectCard.astro';
import PostList from '../components/PostList.astro';

// Drafts stay visible in dev so they can be previewed, but never ship in a build.
const showDrafts = import.meta.env.DEV;

const featured = (
  await getCollection('projects', ({ data }) => (showDrafts || !data.draft) && data.featured)
)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);

const latestPosts = (await getCollection('writing', ({ data }) => showDrafts || !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<Base
  title="Shahar Kozniak | AI & Automation Developer"
  description="Shahar Kozniak builds systems that replace manual work: AI agents, smart automations, and backend platforms."
>
  <section class="hero">
    <div class="hero-text">
      <p class="eyebrow">AI &amp; Automation Developer</p>
      <h1>Shahar Kozniak<span class="gradient-text">.</span></h1>
      <p class="tagline">
        I build systems that replace manual work: AI agents, smart
        automations, and backend platforms.
      </p>
      <p class="intro muted">
        Most recently: a platform that audits Windows server fleets on its
        own, a smart kennel system built on a Raspberry Pi, and internal
        tools that operations teams use every day.
      </p>
      <p class="status"><span class="status-dot" aria-hidden="true"></span>Open to opportunities</p>
      <div class="cta">
        <a class="btn btn-primary" href="/projects/">View projects</a>
        <a class="btn btn-ghost" href="mailto:kshahar1315@gmail.com">Email me</a>
      </div>
    </div>
  </section>

  <Section eyebrow="Selected work" title="Projects" moreHref="/projects/">
    <div class="project-list">
      {featured.map((project) => <ProjectCard project={project} />)}
    </div>
  </Section>

  {
    latestPosts.length > 0 && (
      <Section eyebrow="Notes" title="Writing" moreHref="/writing/">
        <PostList posts={latestPosts} />
      </Section>
    )
  }

  <section class="section contact-cta">
    <p class="eyebrow">Contact</p>
    <h2>Get in <span class="gradient-text">touch</span></h2>
    <p class="muted">
      I'm open to AI, automation and backend roles. The button below opens an email to me, or just copy the address.
    </p>
    <div class="contact-actions">
      <a class="btn btn-primary" href="mailto:kshahar1315@gmail.com">Email me: kshahar1315@gmail.com</a>
      <a class="btn btn-ghost" href="/Shahar-Kozniak-CV.pdf" target="_blank" rel="noopener">Download CV (PDF)</a>
    </div>
  </section>
</Base>

<style>
  .hero {
    padding-block: var(--space-3xl);
    display: grid;
    grid-template-columns: 1fr;
    align-items: center;
    min-height: 48dvh;
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-lg);
    max-width: 52rem;
  }

  .hero h1 {
    font-size: var(--text-hero);
  }

  .tagline {
    font-family: var(--font-display);
    font-weight: 560;
    font-size: var(--text-xl);
    line-height: 1.25;
  }

  .intro {
    font-size: var(--text-md);
    max-width: 40rem;
  }

  .cta {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
    margin-top: var(--space-sm);
  }

  .project-list {
    display: flex;
    flex-direction: column;
  }

  .status {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--ink-soft);
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
  }

  .status-dot {
    width: 0.5em;
    height: 0.5em;
    border-radius: 50%;
    background: var(--ok);
  }

  .contact-cta {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-md);
    border-top: 1px solid var(--line);
  }

  .contact-cta h2 {
    font-size: var(--text-title);
  }

  .contact-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }
</style>
