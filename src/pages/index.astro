---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Section from '../components/Section.astro';
import ProjectCard from '../components/ProjectCard.astro';
import PostList from '../components/PostList.astro';
import SkillsMarquee from '../components/SkillsMarquee.astro';
import TerminalCard from '../components/TerminalCard.astro';

// Drafts stay visible in dev so they can be previewed, but never ship in a build.
const showDrafts = import.meta.env.DEV;

const featured = (
  await getCollection('projects', ({ data }) => (showDrafts || !data.draft) && data.featured)
)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);

const latestPosts = (await getCollection('writing', ({ data }) => showDrafts || !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<Base
  title="Shahar Kozniak | AI & Automation Developer"
  description="Shahar Kozniak builds systems that replace manual work: AI agents, smart automations, and backend platforms."
>
  <section class="hero">
    <div class="hero-text">
      <p class="eyebrow" data-reveal>AI &amp; Automation Developer</p>
      <h1 data-reveal style="--reveal-delay: 80ms">Shahar Kozniak<span class="gradient-text">.</span></h1>
      <p class="tagline" data-reveal style="--reveal-delay: 160ms">
        I build systems that replace manual work:
        <span class="rotator">
          <span class="rotator-word gradient-text" id="rotator-word">AI agents</span>
        </span>
      </p>
      <p class="intro muted" data-reveal style="--reveal-delay: 240ms">
        Most recently: a platform that audits Windows server fleets on its
        own, a smart kennel system built on a Raspberry Pi, and internal
        tools that operations teams use every day.
      </p>
      <div class="cta" data-reveal style="--reveal-delay: 320ms">
        <a class="btn btn-primary" href="/projects/">View projects</a>
        <a class="btn btn-ghost" href="mailto:kshahar1315@gmail.com">✉ Email me</a>
      </div>
    </div>
    <TerminalCard />
  </section>

  <Section eyebrow="Selected work" title="Projects" index="01" moreHref="/projects/">
    <div class="card-grid">
      {featured.map((project, i) => <ProjectCard project={project} delay={i * 90} />)}
    </div>
  </Section>

  <Section eyebrow="Toolbox" title="Skills" index="02">
    <SkillsMarquee />
  </Section>

  {
    latestPosts.length > 0 && (
      <Section eyebrow="Notes" title="Writing" index="03" moreHref="/writing/">
        <PostList posts={latestPosts} />
      </Section>
    )
  }

  <section class="section contact-cta" data-reveal>
    <p class="eyebrow"><span class="cta-index gradient-text">04.</span> Contact</p>
    <h2>Get in <span class="gradient-text">touch</span></h2>
    <p class="muted">
      I'm open to AI, automation and backend roles. The button below opens an email to me — or just copy the address.
    </p>
    <div class="contact-actions">
      <a class="btn btn-primary" href="mailto:kshahar1315@gmail.com">✉ Email me: kshahar1315@gmail.com</a>
      <a class="btn btn-ghost" href="/Shahar-Kozniak-CV.pdf" target="_blank" rel="noopener">Download CV (PDF)</a>
    </div>
  </section>
</Base>

<script>
  const words = ['AI agents', 'smart automations', 'backend platforms', 'internal tools'];
  const el = document.getElementById('rotator-word');
  if (el && !matchMedia('(prefers-reduced-motion: reduce)').matches) {
    let i = 0;
    setInterval(() => {
      el.classList.add('is-swapping');
      setTimeout(() => {
        i = (i + 1) % words.length;
        el.textContent = words[i];
        el.classList.remove('is-swapping');
      }, 280);
    }, 2600);
  }
</script>

<style>
  .hero {
    padding-block: var(--space-3xl);
    display: grid;
    grid-template-columns: 1fr;
    align-items: center;
    gap: var(--space-2xl);
    min-height: 56dvh;
  }

  @media (min-width: 920px) {
    .hero {
      grid-template-columns: 1.25fr 0.75fr;
    }
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-lg);
    max-width: 52rem;
  }

  .hero h1 {
    font-size: var(--text-hero);
  }

  .tagline {
    font-family: var(--font-display);
    font-weight: 560;
    font-size: var(--text-xl);
    line-height: 1.25;
  }

  .rotator {
    display: inline-block;
  }

  .rotator-word {
    display: inline-block;
    transition: opacity 0.28s ease, transform 0.28s ease;
  }

  .rotator-word.is-swapping {
    opacity: 0;
    transform: translateY(0.5em);
  }

  .intro {
    font-size: var(--text-md);
    max-width: 40rem;
  }

  .cta {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
    margin-top: var(--space-sm);
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(20rem, 1fr));
    gap: var(--space-lg);
  }

  @media (min-width: 68rem) {
    .card-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .contact-cta {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-md);
    border-top: 1px solid var(--line);
  }

  .contact-cta h2 {
    font-size: var(--text-title);
  }

  .contact-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .cta-index {
    font-weight: 700;
    margin-inline-end: 0.2em;
  }
</style>
