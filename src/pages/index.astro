---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SkillsMarquee from '../components/SkillsMarquee.astro';

// Drafts stay visible in dev so they can be previewed, but never ship in a build.
const showDrafts = import.meta.env.DEV;

const featured = (
  await getCollection('projects', ({ data }) => (showDrafts || !data.draft) && data.featured)
)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);
---

<Base
  title="Shahar Kozniak | AI & Automation Developer"
  description="Shahar Kozniak builds systems that replace manual work: AI agents, smart automations, and backend platforms."
>
  <!-- HERO -->
  <header id="top" class="container hero">
    <p class="eyebrow rise" style="animation-delay: 0.05s">AI &amp; Automation Developer</p>
    <h1 class="rise" style="animation-delay: 0.15s">
      Systems that replace manual work.<br />
      <span class="faded">AI agents, smart automations, and backend platforms.</span>
    </h1>
    <div class="hero-row rise" style="animation-delay: 0.3s">
      <p class="intro">
        I find the processes that eat someone's hours every week and replace
        them with software that runs on its own. Most recently: a platform
        that audits Windows server fleets by itself, and internal tools that
        operations teams use every day.
      </p>
      <div class="hero-links">
        <a class="link" href="#work">View work</a>
        <a class="link" href="/Shahar-Kozniak-CV.pdf">Curriculum vitae</a>
      </div>
    </div>
    <p class="availability rise" style="animation-delay: 0.45s">
      <span class="dot" aria-hidden="true"></span>Currently open to AI, automation and backend roles
    </p>
  </header>

  <!-- WORK -->
  <section id="work" class="band" data-reveal>
    <div class="container section-pad">
      <div class="section-head">
        <h2>Selected Work</h2>
        <span class="section-num">01</span>
      </div>
      <div class="work-list">
        {featured.map((project) => <ProjectCard project={project} />)}
      </div>
      <a class="link all-link" href="/projects/">All projects</a>
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about" class="band" data-reveal>
    <div class="container section-pad about-grid">
      <div class="section-head about-head">
        <h2>About</h2>
        <span class="section-num">02</span>
      </div>
      <div>
        <p class="about-lede">
          I plan before I build. Unknowns get mapped first and resolved in
          order of risk, decisions run on data rather than gut feeling, and I
          hold a high bar for what leaves my hands. I would rather ship fewer
          things that hold up than many things that almost do.
        </p>
        <div class="about-rows">
          <div class="about-row">
            <span class="about-key">Automation that pays for itself</span>
            <span class="about-val">A platform that turned a multi-day manual server audit into a background job.</span>
          </div>
          <div class="about-row">
            <span class="about-key">Working with AI seriously</span>
            <span class="about-val">Agents and AI tooling are part of how I build now, and I invest in getting better at them constantly.</span>
          </div>
          <div class="about-row">
            <span class="about-key">Range on purpose</span>
            <span class="about-val">Backend platforms, IoT hardware, internal tools and customer-facing web. The same discipline across all of them.</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SKILLS -->
  <section id="skills" class="band" data-reveal>
    <div class="container section-pad">
      <div class="section-head">
        <h2>Practice</h2>
        <span class="section-num">03</span>
      </div>
      <SkillsMarquee />
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact" class="band" data-reveal>
    <div class="container contact-pad">
      <div class="section-head">
        <h2>Contact</h2>
        <span class="section-num">04</span>
      </div>
      <p class="contact-lede">
        Open to AI, automation and backend roles.<br />
        <a class="email" href="mailto:kshahar1315@gmail.com">kshahar1315@gmail.com</a>
      </p>
      <div class="contact-links">
        <a href="https://github.com/ShaharKoza">GitHub</a>
        <a href="https://www.linkedin.com/in/shahar-kozniak">LinkedIn</a>
        <a href="/Shahar-Kozniak-CV.pdf">CV, PDF</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .hero {
    padding-block: 84px 76px;
  }

  .rise {
    animation: riseIn 0.7s ease both;
  }

  h1 {
    font-size: var(--text-hero);
    max-width: 820px;
    margin-block: 24px 32px;
  }

  .faded {
    color: var(--ink-45);
  }

  .hero-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: flex-end;
    gap: 32px;
  }

  .intro {
    max-width: 440px;
    font-size: var(--text-body);
    line-height: 1.75;
    color: var(--ink-70);
  }

  .hero-links {
    display: flex;
    gap: 28px;
  }

  .availability {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: var(--text-micro);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-top: 44px;
  }

  .dot {
    width: 6px;
    height: 6px;
    background: var(--accent);
    animation: pulseDot 2.4s ease infinite;
  }

  .section-pad {
    padding-block: 56px 64px;
  }

  .work-list {
    display: flex;
    flex-direction: column;
  }

  .all-link {
    display: inline-block;
    margin-top: 28px;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 56px;
  }

  .about-head {
    margin-bottom: 0;
  }

  .about-lede {
    font-size: var(--text-md);
    line-height: 1.75;
    margin-bottom: 28px;
    color: var(--ink-85);
  }

  .about-rows {
    display: flex;
    flex-direction: column;
  }

  .about-row {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 24px;
    padding-block: 16px;
    border-top: 1px solid var(--line-soft);
  }

  .about-key {
    font-size: var(--text-meta);
    font-weight: 500;
  }

  .about-val {
    font-size: var(--text-meta);
    line-height: 1.65;
    color: var(--ink-65);
  }

  .contact-pad {
    padding-block: 72px 80px;
  }

  .contact-lede {
    font-size: var(--text-title);
    line-height: 1.25;
    letter-spacing: -0.015em;
    max-width: 760px;
    margin-bottom: 36px;
  }

  .email {
    color: var(--accent);
    border-bottom: 1px solid rgba(107, 68, 35, 0.4);
    padding-bottom: 2px;
  }

  .contact-links {
    display: flex;
    gap: 28px;
    font-family: var(--font-mono);
    font-size: 11.5px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .contact-links a {
    border-bottom: 1px solid rgba(38, 32, 26, 0.3);
    padding-bottom: 2px;
  }

  .contact-links a:hover {
    border-color: var(--accent);
  }

  @media (max-width: 860px) {
    .hero {
      padding-block: 56px 48px;
    }

    .about-grid {
      grid-template-columns: 1fr;
      gap: 28px;
    }

    .about-row {
      grid-template-columns: 1fr;
      gap: 6px;
    }
  }
</style>
