---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import ProjectCard from '../../components/ProjectCard.astro';

const showDrafts = import.meta.env.DEV;
const projects = (await getCollection('projects', ({ data }) => showDrafts || !data.draft)).sort(
  (a, b) => a.data.order - b.data.order
);
---

<Base
  title="Projects | Shahar Kozniak"
  description="What Shahar Kozniak has built: automated auditing, AI, IoT, and web systems."
>
  <header class="page-header">
    <p class="eyebrow">Selected work</p>
    <h1>
      Things I've <span class="gradient-text">built</span>
    </h1>
    <p class="muted">
      Real systems solving real problems: what they do and the engineering
      decisions behind them.
    </p>
  </header>

  <div class="project-list">
    {projects.map((project) => <ProjectCard project={project} />)}
  </div>
</Base>

<style>
  .page-header {
    padding-block: var(--space-2xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    max-width: 46rem;
  }

  .page-header h1 {
    font-size: var(--text-title);
  }

  .project-list {
    display: flex;
    flex-direction: column;
    padding-bottom: var(--space-2xl);
  }
</style>
